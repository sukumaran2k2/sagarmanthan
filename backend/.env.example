# Database Configuration
# For local Node (not Docker): use 127.0.0.1 or localhost
# For Docker Compose on Windows/Mac: use host.docker.internal
DB_HOST=host.docker.internal
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=sagarmanthan_revamp

# Application Server Port & JWT Secrets
PORT=3000
JWT_SECRET=your_jwt_secret_key
# Avoid unescaped $ in secrets — Docker Compose treats $VAR as interpolation
CHAINLIT_AUTH_SECRET=your_chainlit_auth_secret
MIKR_REFRESH_SECRET=your_refresh_secret

# SMTP Mail Configurations (e.g. Mailtrap or custom SMTP server)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Google reCAPTCHA Secret Key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# RSA Decryption Private Key (MUST match the public key in frontend .env.example)
